{
  "name": "@jackbryant/forge",
  "version": "0.1.0",
  "description": "A personal developer CLI suite for project scaffolding, repo checks, prompts, recipes, components, launch checks, and dashboards.",
  "type": "module",
  "bin": {
    "forge": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "validate:assets": "tsx scripts/validate-assets.ts",
    "build": "npm run validate:assets && tsup && node scripts/copy-templates.mjs",
    "start": "node dist/index.js",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "keywords": [
    "cli",
    "developer-tools",
    "typescript",
    "automation",
    "scaffolding"
  ],
  "author": "Jackson Bryant",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "oclif": {
    "bin": "forge",
    "dirname": "forge",
    "commands": "./dist/commands",
    "topicSeparator": " "
  },
  "dependencies": {
    "@oclif/core": "^4.11.3",
    "chalk": "^5.6.2",
    "eta": "^4.6.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.5",
    "ora": "^9.4.0",
    "prompts": "^2.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.8.0",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
