{
  "id": "react-vite-tailwind",
  "name": "React + Vite + Tailwind",
  "description": "Vite + React + TypeScript + Tailwind v3 starter.",
  "tags": ["react", "vite", "typescript", "tailwind"],
  "files": [
    { "path": "package.json", "template": "package.json.eta" },
    { "path": "index.html", "template": "index.html.eta" },
    { "path": "src/main.tsx", "template": "src/main.tsx.eta" },
