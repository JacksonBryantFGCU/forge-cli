    { "path": "src/index.css", "template": "src/index.css.eta" },
    { "path": "src/components/.gitkeep", "template": "src/components/.gitkeep.eta" },
    { "path": "src/pages/.gitkeep", "template": "src/pages/.gitkeep.eta" },
    { "path": "tsconfig.json", "template": "tsconfig.json.eta" },
    { "path": "vite.config.ts", "template": "vite.config.ts.eta" },
    { "path": "tailwind.config.js", "template": "tailwind.config.js.eta" },
    { "path": "postcss.config.js", "template": "postcss.config.js.eta" },
    { "path": ".gitignore", "template": ".gitignore.eta" },
